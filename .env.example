# ─── Pipedrive → Sevdesk Agent – Umgebungsvariablen ──────────────────────────
# Kopiere diese Datei nach .env und fülle alle Werte aus.
# Die .env Datei NIEMALS in Git committen!

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Pipedrive ─────────────────────────────────────────────────────────────────
PIPEDRIVE_API_TOKEN=...
PIPEDRIVE_DOMAIN=vollpension          # Nur der Subdomain-Teil: vollpension.pipedrive.com → "vollpension"

# ── Pipedrive Pipeline / Stage IDs ───────────────────────────────────────────
# Findest du via API: GET https://vollpension.pipedrive.com/api/v1/stages?pipeline_id=X&api_token=TOKEN
# Oder in Pipedrive: Einstellungen → Pipelines → Stage anklicken → ID in der URL
PIPEDRIVE_PIPELINE_ID=1
PIPEDRIVE_STAGE_ANFRAGEN=1
PIPEDRIVE_STAGE_IN_BEARBEITUNG=3
PIPEDRIVE_STAGE_ANGEBOT_GELEGT=4

# ── Sevdesk ───────────────────────────────────────────────────────────────────
SEVDESK_API_TOKEN=...

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...             # Bot User OAuth Token (Slack App → OAuth & Permissions)
SLACK_SIGNING_SECRET=...             # Signing Secret (Slack App → Basic Information)
SLACK_CHANNEL_OFFERS=C...            # Channel-ID für Angebots-Freigaben
SLACK_CHANNEL_INVOICES=C...          # Channel-ID für Rechnungen + Mahnungen
SLACK_PERSON1_ID=U...                # Slack User-ID Vertrieb (Profil → ⋮ → "Member-ID kopieren")
SLACK_PERSON2_ID=U...                # Slack User-ID Buchhaltung

# ── Sicherheit ────────────────────────────────────────────────────────────────
# Beliebige lange Zufallsstrings – z.B. via: openssl rand -hex 32
WEBHOOK_SECRET=                      # Pipedrive Webhook Basic-Auth Passwort
CRON_SECRET=                         # Schutz für /cron/dunning-check
ADMIN_SECRET=                        # Schutz für /admin/* Endpoints
